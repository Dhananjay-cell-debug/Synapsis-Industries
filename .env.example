# ─── Synapsis Industries — Environment Variables ─────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# NextAuth (Google OAuth)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Admin lock — only this email can access /admin routes
ADMIN_EMAIL=you@example.com

# Gmail (nodemailer for transactional emails)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Stripe (LEGACY — parked, Synapsis is now INR via Razorpay)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Groq (AI chat builder for blueprint + discovery)
GROQ_API_KEY=gsk_xxx

# ─── RAZORPAY (ACTIVE PAYMENT GATEWAY) ──────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com/
# Start TEST. Switch to live keys only after Phase 3 flow verified end-to-end.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Public key ID — exposed in browser for Razorpay checkout widget. Same value as above.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
