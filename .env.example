# ─── Synapsis Industries — Environment Variables ─────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# ─── NextAuth (Google OAuth) ─────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Admin lock — only this email can access /admin routes
ADMIN_EMAIL=dhananjaychitmila@gmail.com

# ─── Gmail (nodemailer for transactional + invoice emails) ──────────────────
GMAIL_USER=dhananjaychitmila@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ─── Groq (AI chat builder for blueprint + discovery) ───────────────────────
GROQ_API_KEY=gsk_xxx

# ─── RAZORPAY (ACTIVE PAYMENT GATEWAY) ──────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com/
# Use LIVE keys for real transactions.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx

# ─── SUPABASE (synapsis schema — payments + invoices + transactions) ────────
# Project: VELT (uslmejdctlglropgqzmc) → schema "synapsis"
SUPABASE_URL=https://uslmejdctlglropgqzmc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://uslmejdctlglropgqzmc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx

# ─── SYNAPSIS BUSINESS DETAILS (used in invoice PDFs + NEFT instructions) ───
# Public-safe values (visible to clients on invoices). Last-4 digits ONLY.
NEXT_PUBLIC_SYNAPSIS_PAN_LAST4=XXXX
NEXT_PUBLIC_SYNAPSIS_UDYAM=UDYAM-XX-XX-XXXXXXX
NEXT_PUBLIC_SYNAPSIS_BANK_NAME=YOUR_BANK
NEXT_PUBLIC_SYNAPSIS_BANK_BRANCH=YOUR_BRANCH
NEXT_PUBLIC_SYNAPSIS_IFSC=IFSC0000000
NEXT_PUBLIC_SYNAPSIS_ACCOUNT_LAST4=XXXX
NEXT_PUBLIC_SYNAPSIS_UPI=
NEXT_PUBLIC_SYNAPSIS_ADDR1=Registered Address Line 1
NEXT_PUBLIC_SYNAPSIS_ADDR2=Address Line 2
NEXT_PUBLIC_SYNAPSIS_CITY=Mumbai
NEXT_PUBLIC_SYNAPSIS_STATE=Maharashtra
NEXT_PUBLIC_SYNAPSIS_PIN=400001
